# Franklin Frontend Environment Variables
# Copy this to .env.local for local development
# Set these in Render dashboard for production deployment

# Backend API (Node.js)
VITE_API_BASE_URL=http://localhost:5002
# Production: https://franklin-backend-v0i3.onrender.com

# AI Service (FastAPI)
VITE_AI_SERVICE_URL=http://localhost:8000
# Production: https://franklin-ai.onrender.com

# Optional: Override individual model URLs (defaults to VITE_AI_SERVICE_URL)
# VITE_UNIFIED_MODEL_URL=http://localhost:8000
# VITE_DISEASE_MODEL_URL=http://localhost:8000
# VITE_SHORELINE_MODEL_URL=http://localhost:8000
# VITE_HATCHERY_MODEL_URL=http://localhost:8000
